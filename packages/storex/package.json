{
  "name": "storex",
  "version": "0.1.0",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./devtools": {
      "types": "./dist/devtools.d.ts",
      "import": "./dist/devtools.js"
    },
    "./persist": {
      "types": "./dist/persist.d.ts",
      "import": "./dist/persist.js"
    },
    "./ssr": {
      "types": "./dist/ssr.d.ts",
      "import": "./dist/ssr.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json"
  },
  "dependencies": {
    "@storex/core": "workspace:*",
    "@storex/devtools": "workspace:*",
    "@storex/persist": "workspace:*",
    "@storex/ssr": "workspace:*",
    "@storex/testing": "workspace:*"
  },
  "peerDependencies": {
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "vue": "^3.5.13"
  },
  "license": "MIT",
  "description": "Umbrella package: core + persist + devtools + ssr + testing.",
  "keywords": [
    "storex",
    "vue",
    "vue3",
    "state",
    "pinia"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/abdallhsamy/StoreX.git",
    "directory": "packages/storex"
  },
  "bugs": {
    "url": "https://github.com/abdallhsamy/StoreX/issues"
  },
  "homepage": "https://github.com/abdallhsamy/StoreX#readme",
  "engines": {
    "node": ">=18"
  }
}
